# ============ Warum OBYRA wählen ============
msgid "Por qué elegir"
msgstr "Warum"

msgid "Herramientas profesionales diseñadas para la industria de la construcción"
msgstr "Professionelle Werkzeuge für die Bauindustrie"

msgid "Visibilidad Total"
msgstr "Vollständige Transparenz"

msgid "Monitorea el avance de cada obra, controla presupuestos y detecta desvíos en tiempo real desde cualquier dispositivo."
msgstr "Überwachen Sie den Fortschritt jedes Projekts, kontrollieren Sie Budgets und erkennen Sie Abweichungen in Echtzeit von jedem Gerät aus."

msgid "Colaboración Ágil"
msgstr "Agile Zusammenarbeit"

msgid "Coordina equipos en obra y oficina, asigna tareas y comparte documentación con un flujo de trabajo integrado."
msgstr "Koordinieren Sie Bau- und Büroteams, weisen Sie Aufgaben zu und teilen Sie Dokumentation mit einem integrierten Workflow."

msgid "Automatización IA"
msgstr "KI-Automatisierung"

msgid "Aprovecha asistentes inteligentes para presupuestos, análisis de costos y reportes que te ayudan a tomar mejores decisiones."
msgstr "Nutzen Sie intelligente Assistenten für Budgets, Kostenanalysen und Berichte, die Ihnen helfen, bessere Entscheidungen zu treffen."

# ============ So funktioniert es ============
msgid "Cómo funciona"
msgstr "So funktioniert"

msgid "Empezá a optimizar tus obras en 3 simples pasos"
msgstr "Optimieren Sie Ihre Projekte in 3 einfachen Schritten"

msgid "Creá tu cuenta"
msgstr "Konto erstellen"

msgid "Registrate gratis y configurá tu organización en menos de 5 minutos. Sin tarjeta de crédito."
msgstr "Registrieren Sie sich kostenlos und richten Sie Ihre Organisation in weniger als 5 Minuten ein. Keine Kreditkarte erforderlich."

msgid "Cargá tus obras"
msgstr "Projekte hinzufügen"

msgid "Agregá tus proyectos activos, invitá a tu equipo y empezá a centralizar toda la información."
msgstr "Fügen Sie Ihre aktiven Projekte hinzu, laden Sie Ihr Team ein und beginnen Sie, alle Informationen zu zentralisieren."

msgid "Optimizá tu gestión"
msgstr "Verwaltung optimieren"

msgid "Controlá presupuestos, gestioná compras y tomá decisiones con datos en tiempo real."
msgstr "Kontrollieren Sie Budgets, verwalten Sie Einkäufe und treffen Sie Entscheidungen mit Echtzeitdaten."

